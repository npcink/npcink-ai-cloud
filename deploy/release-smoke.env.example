# Copy this file outside the repository or into .tmp/release-smoke.env before use.
# Never commit the filled file. Keep permissions tight, for example:
#   chmod 600 .tmp/release-smoke.env

NPCINK_CLOUD_BASE_URL=https://cloud.npc.ink

# Internal service checks.
NPCINK_CLOUD_INTERNAL_AUTH_TOKEN=

# Admin bootstrap smoke.
NPCINK_CLOUD_ADMIN_BOOTSTRAP_TOKEN=

# Real Portal mailbox smoke. Request the code first, then paste the received
# code here immediately before running the full release smoke. When this value
# is set, release-smoke.sh skips requesting a replacement code.
NPCINK_CLOUD_RELEASE_MEMBER_EMAIL=
NPCINK_CLOUD_PORTAL_LOGIN_CODE=

# Signed hosted runtime smoke.
NPCINK_CLOUD_RELEASE_SITE_ID=
NPCINK_CLOUD_RELEASE_KEY_ID=
NPCINK_CLOUD_RELEASE_KEY_SECRET=
