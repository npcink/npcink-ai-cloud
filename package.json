{
  "name": "npcink-ai-cloud",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yml up --build",
    "dev:runtime": "docker compose -f docker-compose.dev.yml --profile runtime up --build",
    "dev:callback": "docker compose -f docker-compose.dev.yml --profile runtime --profile callback up --build",
    "dev:ops": "docker compose -f docker-compose.dev.yml --profile runtime --profile callback --profile ops up --build",
    "test": "docker compose -f docker-compose.dev.yml run --rm -e NPCINK_CLOUD_OPENAI_API_KEY= api pytest",
    "test:contract": "docker compose -f docker-compose.dev.yml run --rm -e NPCINK_CLOUD_OPENAI_API_KEY= api pytest tests/contract",
    "test:api": "docker compose -f docker-compose.dev.yml run --rm -e NPCINK_CLOUD_OPENAI_API_KEY= api pytest tests/api",
    "test:domain": "docker compose -f docker-compose.dev.yml run --rm -e NPCINK_CLOUD_OPENAI_API_KEY= api pytest tests/domain",
    "check:fast": "pnpm run test:contract && pnpm run test:domain",
    "check:release-policy": "bash scripts/check-release-policy.sh",
    "check:pr-backend": "bash scripts/check-pr-backend-gate.sh",
    "check:seam": "pnpm run test:api && pnpm run check:perimeter",
    "check:perimeter": "make perimeter",
    "check:anti-drift": "node scripts/check-cloud-anti-drift.js && node scripts/check-provider-env-retirement.js",
    "test:anti-drift": "node scripts/test-cloud-anti-drift.js && node scripts/test-provider-env-retirement.js",
    "lint": "docker compose -f docker-compose.dev.yml run --rm api ruff check . && docker compose -f docker-compose.dev.yml run --rm api mypy app",
    "build": "docker compose -f docker-compose.prod.yml build",
    "seed:dev": "docker compose -f docker-compose.dev.yml run --rm api python -m app.dev.seed_runtime --site-id site_smoke --key-id key_default --secret npcink-cloud-test-secret",
    "seed:smoke": "pnpm run seed:dev",
    "providers:import-env": "python -m app.dev.import_provider_connections_from_env",
    "smoke:provider-env-retirement": "bash scripts/provider-env-retirement-smoke.sh",
    "login:seed:dev": "bash dev/bootstrap-local-login-dev.sh",
    "smoke:local-alpha": "bash scripts/local-alpha-smoke.sh",
    "smoke:internal-alpha-onboarding": "uv run pytest tests/api/test_internal_alpha_onboarding_flow.py -q",
    "smoke:site-knowledge": "bash scripts/site-knowledge-real-chain-smoke.sh",
    "smoke:media-derivative:wp": "bash scripts/media-derivative-wordpress-e2e-smoke.sh",
    "drill:provider-failure": "bash scripts/local-alpha-provider-failure-drill.sh",
    "drill:callback-failure": "bash scripts/local-alpha-callback-failure-drill.sh",
    "drill:auth-failure": "bash scripts/local-alpha-auth-failure-drill.sh",
    "frontend:sync": "make frontend-sync",
    "frontend:watch": "make frontend-watch",
    "check:frontend-locks": "node scripts/check-frontend-lock-sync.js",
    "frontend:doctor": "bash scripts/dev-frontend-doctor.sh",
    "frontend:recover": "bash scripts/dev-frontend-recover.sh",
    "frontend:type-check": "cd frontend && ./node_modules/.bin/tsc --noEmit",
    "frontend:lint": "cd frontend && ./node_modules/.bin/eslint . --max-warnings=0",
    "frontend:test:i18n-contract": "pnpm --dir frontend run test:i18n-contract",
    "frontend:test:e2e:agent-workflow-metadata": "pnpm --dir frontend run test:e2e:agent-workflow-metadata",
    "check:agent-workflow-metadata": "pnpm run frontend:test:e2e:agent-workflow-metadata",
    "frontend:test:e2e:admin-operator-path": "CLOUD_API_BASE_URL=${CLOUD_API_BASE_URL:-https://api.example.com} CLOUD_PUBLIC_BASE_URL=${CLOUD_PUBLIC_BASE_URL:-https://cloud.example.com} pnpm --dir frontend run test:e2e:admin-operator-path",
    "frontend:test:e2e:portal-workspace-path": "pnpm --dir frontend run test:e2e:portal-workspace-path",
    "frontend:test:e2e:portal-addon-binding": "pnpm --dir frontend run test:e2e:portal-addon-binding",
    "portal:bind:dev": "bash dev/bootstrap-portal-site-dev.sh",
    "portal:bind:ssh": "bash deploy/bootstrap-portal-site-to-ssh-host.sh",
    "portal:smoke:ssh": "bash deploy/portal-smoke-to-ssh-host.sh",
    "smoke:small-trial-preflight": "bash deploy/small-customer-trial-preflight.sh",
    "bundle": "bash deploy/bundle-images.sh",
    "deploy:ssh": "bash deploy/deploy-to-ssh-host.sh",
    "deploy:static-terms:ssh": "bash deploy/deploy-static-terms-to-ssh-host.sh",
    "env:ssh": "bash deploy/env-to-ssh-host.sh",
    "wp-cron:ssh": "bash deploy/wp-cron-to-ssh-host.sh",
    "sync:mini": "pnpm run mini:preview:frontend",
    "sync:mini:local-build": "pnpm run mini:preview:frontend:local-build",
    "mini:preview": "bash scripts/remote-preview-mini.sh --build-remote",
    "mini:preview:local-build": "bash scripts/remote-preview-mini.sh --build-local",
    "mini:preview:frontend": "SERVICES=frontend bash scripts/remote-preview-mini.sh --build-remote",
    "mini:preview:frontend:local-build": "SERVICES=frontend bash scripts/remote-preview-mini.sh --build-local",
    "mini:preview:logs": "bash scripts/remote-preview-mini-logs.sh",
    "mini:preview:restart": "bash scripts/remote-preview-mini-restart.sh",
    "mini:preview:stop": "bash scripts/remote-preview-mini-stop.sh",
    "mini:deploy": "bash scripts/mini-cloud-deploy.sh",
    "check:frontend-handoff": "node scripts/check-cloud-frontend-handoff.js",
    "check:frontend-scope": "node scripts/check-cloud-frontend-scope.js",
    "check:agent-feedback-quality": "bash scripts/check-agent-feedback-quality.sh",
    "check:runtime-stability-plan": "node scripts/check-runtime-stability-evidence-plan.js",
    "check:visual:frontend": "pnpm --dir frontend run test:visual",
    "check:e2e:deploy-bundle:smoke": "bash scripts/cloud-deploy-bundle-smoke-flow.sh",
    "perf:runtime-hot-path": "docker compose -f docker-compose.dev.yml run --rm api python scripts/runtime_hot_path_explain.py --format json",
    "perf:runtime-hot-path:require-indexes": "docker compose -f docker-compose.dev.yml run --rm api python scripts/runtime_hot_path_explain.py --format json --require-indexes",
    "perf:production-baseline": "python scripts/production_performance_baseline.py --format json --require-indexes",
    "perf:production-baseline:ssh": "bash deploy/production-performance-baseline-to-ssh-host.sh",
    "release:timing": "python3 scripts/report-release-timing.py",
    "release:junit-timing": "python3 scripts/report-junit-timing.py",
    "smoke:prod-python-extras": "bash scripts/production-python-extras-smoke.sh",
    "scaffold:route": "node scripts/scaffold-cloud-route.js",
    "scaffold:portal-route": "node scripts/scaffold-cloud-portal-route.js",
    "scaffold:frontend-handoff": "node scripts/scaffold-cloud-frontend-handoff.js"
  }
}
