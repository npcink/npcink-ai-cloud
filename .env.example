MAGICK_CLOUD_PROJECT_NAME=Magick AI Cloud
MAGICK_CLOUD_ENVIRONMENT=development
MAGICK_CLOUD_LOG_LEVEL=INFO
MAGICK_CLOUD_HOST=0.0.0.0
MAGICK_CLOUD_PORT=8000
MAGICK_CLOUD_DATABASE_URL=postgresql+psycopg://magick:magick@postgres:5432/magick_ai_cloud
MAGICK_CLOUD_REDIS_URL=redis://redis:6379/0
MAGICK_CLOUD_RUNTIME_WORKER_POLL_SECONDS=5
MAGICK_CLOUD_RUNTIME_CALLBACK_WORKER_POLL_SECONDS=5
MAGICK_CLOUD_WORKER_HEARTBEAT_INTERVAL_SECONDS=60
MAGICK_CLOUD_OPS_CADENCE_POLL_SECONDS=30
MAGICK_CLOUD_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
MAGICK_CLOUD_PLUGIN_OBSERVABILITY_RETENTION_DAYS=180
MAGICK_CLOUD_PLUGIN_OBSERVABILITY_CLEANUP_INTERVAL_SECONDS=86400
MAGICK_CLOUD_USAGE_ROLLUP_INTERVAL_SECONDS=3600
MAGICK_CLOUD_ROUTER_DIAGNOSTICS_INTERVAL_SECONDS=900
MAGICK_CLOUD_LATENCY_PROBE_INTERVAL_SECONDS=900
MAGICK_CLOUD_ALERT_PROVIDER_DEGRADATION_INTERVAL_SECONDS=900
MAGICK_CLOUD_PROVIDER_HEALTH_SCAN_INTERVAL_SECONDS=900

# Production-style deploys: required
MAGICK_CLOUD_INTERNAL_AUTH_TOKEN=
MAGICK_CLOUD_ADMIN_BOOTSTRAP_TOKEN=
MAGICK_CLOUD_ADMIN_SESSION_SECRET=
MAGICK_CLOUD_BROWSER_ORIGIN_ALLOWLIST=
MAGICK_CLOUD_TRUSTED_HOST_ALLOWLIST=

# Development-only helpers
# Local compose can temporarily allow the internal token fallback. Remote,
# staging, and release envs should keep this false.
MAGICK_CLOUD_ALLOW_DEV_ADMIN_INTERNAL_TOKEN_FALLBACK=false
MAGICK_CLOUD_ADMIN_SESSION_TTL_SECONDS=28800
MAGICK_CLOUD_ADMIN_BOOTSTRAP_ADMIN_REF=platform:internal_root
MAGICK_CLOUD_ADMIN_BOOTSTRAP_ADMIN_ROLE=platform_admin

# Portal login and session signing: required for invited site-admin login
# Production deploys should also set the public base URL and SMTP sender values.
MAGICK_CLOUD_PORTAL_JWT_SECRET=
MAGICK_CLOUD_PORTAL_JWT_ALGORITHM=HS256
MAGICK_CLOUD_PORTAL_JWT_ISSUER=
MAGICK_CLOUD_PORTAL_JWT_AUDIENCE=
MAGICK_CLOUD_PORTAL_PUBLIC_BASE_URL=

# SMTP delivery: required for production-style portal login email delivery
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_HOST=
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_PORT=465
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_USERNAME=
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_PASSWORD=
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_USE_SSL=true
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_USE_STARTTLS=false
MAGICK_CLOUD_PORTAL_EMAIL_SMTP_TIMEOUT_SECONDS=20
MAGICK_CLOUD_PORTAL_EMAIL_FROM_EMAIL=
MAGICK_CLOUD_PORTAL_EMAIL_FROM_NAME=Magick AI Cloud
MAGICK_CLOUD_PORTAL_EMAIL_REPLY_TO=
MAGICK_CLOUD_OTEL_SERVICE_NAME=magick-ai-cloud
MAGICK_CLOUD_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
MAGICK_CLOUD_OTEL_TRACE_SINK_OTLP_ENDPOINT=jaeger:4317
MAGICK_CLOUD_OTEL_TRACE_QUERY_URL=http://127.0.0.1:16686
# Optional bounded runtime/admin kill switches. JSON object only; values must be booleans.
# Example: {"portal.billing.readonly.enabled":false,"runtime.experimental_probe.enabled":true}
MAGICK_CLOUD_FEATURE_FLAGS_JSON=
MAGICK_CLOUD_OPENAI_BASE_URL=https://api.openai.com/v1
MAGICK_CLOUD_OPENAI_API_KEY=
MAGICK_CLOUD_OPENAI_ORGANIZATION=
MAGICK_CLOUD_OPENAI_TIMEOUT_SECONDS=30

# Dev-only fixture catalog profiles. Leave empty for staging/production deploys.
MAGICK_CLOUD_OPENAI_SAMPLE_CATALOG_PROFILE=
MAGICK_CLOUD_LITELLM_PROVIDER_ENABLED=false
MAGICK_CLOUD_LITELLM_BASE_URL=
MAGICK_CLOUD_LITELLM_API_KEY=
MAGICK_CLOUD_LITELLM_TIMEOUT_SECONDS=30
MAGICK_CLOUD_VLLM_PROVIDER_ENABLED=false
MAGICK_CLOUD_VLLM_BASE_URL=
MAGICK_CLOUD_VLLM_API_KEY=
MAGICK_CLOUD_VLLM_TIMEOUT_SECONDS=30
MAGICK_CLOUD_TEI_PROVIDER_ENABLED=false
MAGICK_CLOUD_TEI_BASE_URL=
MAGICK_CLOUD_TEI_API_KEY=
MAGICK_CLOUD_TEI_TIMEOUT_SECONDS=30
MAGICK_CLOUD_TEI_MODEL_IDS=
MAGICK_CLOUD_TEI_REGION=self-hosted
MAGICK_CLOUD_TEI_CONTEXT_WINDOW=8192
MAGICK_CLOUD_INTERNAL_OPS_SUMMARIZER_PROVIDER_ALLOWLIST=
MAGICK_CLOUD_OPENROUTER_PROVIDER_ENABLED=false
MAGICK_CLOUD_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MAGICK_CLOUD_OPENROUTER_API_KEY=
MAGICK_CLOUD_OPENROUTER_TIMEOUT_SECONDS=30
MAGICK_CLOUD_OPENROUTER_SITE_URL=
MAGICK_CLOUD_SILICONFLOW_PRICING_URL=https://www2.siliconflow.cn/pricing
MAGICK_CLOUD_SILICONFLOW_TIMEOUT_SECONDS=30
MAGICK_CLOUD_OLLAMA_BASE_URL=
MAGICK_CLOUD_OLLAMA_API_KEY=
MAGICK_CLOUD_OLLAMA_TIMEOUT_SECONDS=30
MAGICK_CLOUD_OLLAMA_MODEL_ALLOWLIST=
MAGICK_CLOUD_OLLAMA_CATALOG_ENABLED=false
MAGICK_CLOUD_OLLAMA_CATALOG_LIMIT=250
MAGICK_CLOUD_ANTHROPIC_BASE_URL=https://api.anthropic.com
MAGICK_CLOUD_ANTHROPIC_API_KEY=
MAGICK_CLOUD_ANTHROPIC_VERSION=2023-06-01
MAGICK_CLOUD_ANTHROPIC_TIMEOUT_SECONDS=30
MAGICK_CLOUD_PIP_INDEX_URL=
MAGICK_CLOUD_PIP_EXTRA_INDEX_URL=
MAGICK_CLOUD_PIP_TRUSTED_HOST=

# Compliance premium layer
# Deployment region shown in portal compliance posture (e.g., ap-east-1, eu-west-1, us-east-1)
MAGICK_CLOUD_DEPLOYMENT_REGION=unspecified
# Default audit retention days when tier cannot be resolved (overridden by plan tier: starter=30, pro=90, enterprise=365)
MAGICK_CLOUD_AUDIT_RETENTION_DAYS_DEFAULT=90
