NPCINK_CLOUD_PROJECT_NAME=Npcink AI Cloud
NPCINK_CLOUD_ENVIRONMENT=development
NPCINK_CLOUD_LOG_LEVEL=INFO
NPCINK_CLOUD_HOST=0.0.0.0
NPCINK_CLOUD_PORT=8000
NPCINK_CLOUD_DATABASE_URL=postgresql+psycopg://npcink:npcink@postgres:5432/npcink_ai_cloud
NPCINK_CLOUD_REDIS_URL=redis://redis:6379/0
NPCINK_CLOUD_RUNTIME_WORKER_POLL_SECONDS=5
NPCINK_CLOUD_RUNTIME_CALLBACK_WORKER_POLL_SECONDS=5
NPCINK_CLOUD_WORKER_HEARTBEAT_INTERVAL_SECONDS=60
NPCINK_CLOUD_OPS_CADENCE_POLL_SECONDS=30
NPCINK_CLOUD_RETENTION_CLEANUP_INTERVAL_SECONDS=3600
NPCINK_CLOUD_PLUGIN_OBSERVABILITY_RETENTION_DAYS=180
NPCINK_CLOUD_PLUGIN_OBSERVABILITY_CLEANUP_INTERVAL_SECONDS=86400
NPCINK_CLOUD_USAGE_ROLLUP_INTERVAL_SECONDS=3600
NPCINK_CLOUD_ROUTER_DIAGNOSTICS_INTERVAL_SECONDS=900
NPCINK_CLOUD_LATENCY_PROBE_INTERVAL_SECONDS=900
NPCINK_CLOUD_ALERT_PROVIDER_DEGRADATION_INTERVAL_SECONDS=900
NPCINK_CLOUD_HOSTED_MODEL_GOVERNANCE_INTERVAL_SECONDS=3600
NPCINK_CLOUD_PROVIDER_HEALTH_SCAN_INTERVAL_SECONDS=900
NPCINK_CLOUD_HOSTED_MODEL_GOVERNANCE_WORKER_RECENT_MINUTES=1440
NPCINK_CLOUD_HOSTED_MODEL_GOVERNANCE_WORKER_LIMIT=25

# Production-style deploys: required
NPCINK_CLOUD_INTERNAL_AUTH_TOKEN=
NPCINK_CLOUD_ADMIN_BOOTSTRAP_TOKEN=
NPCINK_CLOUD_ADMIN_SESSION_SECRET=
NPCINK_CLOUD_BROWSER_ORIGIN_ALLOWLIST=
NPCINK_CLOUD_TRUSTED_HOST_ALLOWLIST=

# Development-only helpers
# Local compose can temporarily allow the internal token fallback. Remote,
# staging, and release envs should keep this false.
NPCINK_CLOUD_ALLOW_DEV_ADMIN_INTERNAL_TOKEN_FALLBACK=false
NPCINK_CLOUD_ADMIN_SESSION_TTL_SECONDS=28800
NPCINK_CLOUD_ADMIN_BOOTSTRAP_ADMIN_REF=platform:internal_root
NPCINK_CLOUD_ADMIN_BOOTSTRAP_ADMIN_ROLE=platform_admin
NPCINK_CLOUD_DEV_PORTAL_EMAIL=portal-demo@example.com
NPCINK_CLOUD_DEV_PORTAL_SITE_ID=site_smoke

# Portal login and session signing: required for invited site-admin login.
# Portal public URL, QQ login, and SMTP sender values are configured in
# `/admin/service-settings`, not `.env`.
NPCINK_CLOUD_PORTAL_JWT_SECRET=
NPCINK_CLOUD_PORTAL_JWT_ALGORITHM=HS256
NPCINK_CLOUD_PORTAL_JWT_ISSUER=
NPCINK_CLOUD_PORTAL_JWT_AUDIENCE=
NPCINK_CLOUD_OTEL_SERVICE_NAME=npcink-ai-cloud
NPCINK_CLOUD_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
NPCINK_CLOUD_OTEL_TRACE_SINK_OTLP_ENDPOINT=jaeger:4317
NPCINK_CLOUD_OTEL_TRACE_QUERY_URL=http://127.0.0.1:16686
# Optional bounded runtime/admin kill switches. JSON object only; values must be booleans.
# Example: {"portal.billing.readonly.enabled":false,"runtime.experimental_probe.enabled":true}
NPCINK_CLOUD_FEATURE_FLAGS_JSON=
# AI provider channels are managed in Cloud runtime storage through
# `/admin/ai-resources`, not through `.env.local` provider keys.
NPCINK_CLOUD_AUDIO_SUMMARY_TEXT_PROFILE_ID=text.ai
NPCINK_CLOUD_AUDIO_NARRATION_PROFILE_ID=audio.narration.default
NPCINK_CLOUD_AUDIO_SUMMARY_AUDIO_PROFILE_ID=audio.narration.default
NPCINK_CLOUD_INTERNAL_OPS_SUMMARIZER_PROVIDER_ALLOWLIST=

# Site Knowledge guardrails stay as runtime configuration. Provider credentials,
# embedding providers, rerank providers, and vector-store suppliers are managed
# in `/admin/ai-resources`.
NPCINK_CLOUD_SITE_KNOWLEDGE_COMMENTS_ENABLED=false
NPCINK_CLOUD_SITE_KNOWLEDGE_RERANK_TOP_K=30
NPCINK_CLOUD_SITE_KNOWLEDGE_RERANK_TIMEOUT_SECONDS=8
NPCINK_CLOUD_SITE_KNOWLEDGE_ZILLIZ_TIMEOUT_SECONDS=10

# Search and image-source suppliers are managed in `/admin/ai-resources`.

NPCINK_CLOUD_PIP_INDEX_URL=
NPCINK_CLOUD_PIP_EXTRA_INDEX_URL=
NPCINK_CLOUD_PIP_TRUSTED_HOST=

# Compliance premium layer
# Deployment region shown in portal compliance posture (e.g., ap-east-1, eu-west-1, us-east-1)
NPCINK_CLOUD_DEPLOYMENT_REGION=unspecified
# Default audit retention days when tier cannot be resolved (overridden by plan tier: starter=30, pro=90, enterprise=365)
NPCINK_CLOUD_AUDIT_RETENTION_DAYS_DEFAULT=90
