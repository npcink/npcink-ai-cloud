# Cloud API Base URL (backend)
CLOUD_API_BASE_URL=http://127.0.0.1:8010

# Public Base URL (frontend)
CLOUD_PUBLIC_BASE_URL=http://127.0.0.1:8010

# Production Admin BFF reads its internal service credential lazily from this
# root-owned mounted file. Do not place the token itself in production env.
NPCINK_CLOUD_INTERNAL_AUTH_TOKEN_FILE=/run/npcink-frontend-config/internal-auth-token

# Development-only shortcuts. Never configure these in production.
# NPCINK_CLOUD_INTERNAL_AUTH_TOKEN=
# NPCINK_CLOUD_DEV_ADMIN_KEY=

# Build-backed Playwright E2E runs should use non-loopback placeholder origins,
# for example:
# CLOUD_API_BASE_URL=https://api.example.com
# CLOUD_PUBLIC_BASE_URL=https://cloud.example.com

# Optional: Portal JWT Secret (server-side only)
# CLOUD_PORTAL_JWT_SECRET=

# Optional: Session config
# CLOUD_SESSION_COOKIE_NAME=npcink_portal_session_token
