{
  "name": "frontend",
  "version": "0.1.0",
  "description": "Npcink AI Cloud Frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "playwright:browsers:check": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.local/share/magick-ai-playwright} pnpm exec playwright install --list",
    "playwright:browsers:install:chromium": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.local/share/magick-ai-playwright} pnpm exec playwright install chromium",
    "playwright:browsers:prune:check": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.local/share/magick-ai-playwright} node ../scripts/prune-cloud-frontend-playwright-cache.js",
    "playwright:browsers:prune": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.local/share/magick-ai-playwright} node ../scripts/prune-cloud-frontend-playwright-cache.js --apply",
    "test:i18n-contract": "pnpm run test:i18n:admin-portal-completeness && node tests/unit/admin-home-support-lookup-contract.mjs && node tests/unit/admin-mutation-receipt-contract.mjs && node tests/unit/admin-vector-observability-i18n-contract.mjs && node tests/unit/admin-media-observability-i18n-contract.mjs && node tests/unit/admin-plugin-observability-i18n-contract.mjs && node tests/unit/admin-agent-feedback-i18n-contract.mjs && node tests/unit/admin-troubleshooting-i18n-contract.mjs && node tests/unit/admin-coverage-workspace-contract.mjs && node tests/unit/admin-layout-i18n-contract.mjs",
    "test:i18n:admin-portal-completeness": "node tests/unit/admin-portal-i18n-completeness-contract.mjs",
    "test:admin-dev-autologin-contract": "node tests/unit/admin-dev-autologin-contract.mjs",
    "test:portal-proxy-contract": "node tests/unit/portal-proxy-contract.mjs",
    "test:portal-package-contract": "node tests/unit/portal-package-contract.mjs",
    "test:copy-surface": "node tests/unit/admin-portal-copy-surface-contract.mjs",
    "test:proxy-csp-contract": "node tests/unit/proxy-csp-contract.mjs",
    "guard:portal-boundary": "node tests/unit/portal-boundary-guard.mjs",
    "test:contracts": "sh -ec 'for test_file in tests/unit/*.mjs; do node \"$test_file\"; done'",
    "test:e2e": "node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts",
    "test:e2e:admin-operator-path": "CLOUD_API_BASE_URL=${CLOUD_API_BASE_URL:-https://api.example.com} CLOUD_PUBLIC_BASE_URL=${CLOUD_PUBLIC_BASE_URL:-https://cloud.example.com} node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/admin-operator-path.spec.ts",
    "test:e2e:admin-operator-path:ci": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.local/share/magick-ai-playwright} CLOUD_API_BASE_URL=${CLOUD_API_BASE_URL:-https://api.example.com} CLOUD_PUBLIC_BASE_URL=${CLOUD_PUBLIC_BASE_URL:-https://cloud.example.com} node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/admin-operator-path.spec.ts",
    "test:e2e:portal-workspace-path": "CLOUD_API_BASE_URL=${CLOUD_API_BASE_URL:-https://api.example.com} CLOUD_PUBLIC_BASE_URL=${CLOUD_PUBLIC_BASE_URL:-https://cloud.example.com} node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/portal-workspace-path.spec.ts",
    "test:e2e:portal-addon-binding": "node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/portal-login.spec.ts",
    "test:e2e:agent-workflow-metadata": "NPCINK_CLOUD_FRONTEND_BASE_URL=${NPCINK_CLOUD_FRONTEND_BASE_URL:-http://127.0.0.1:8010} node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/agent-workflow-metadata-smoke.spec.ts",
    "test:visual": "node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/marketing-home.spec.ts tests/e2e/portal-login.spec.ts tests/e2e/visual-baseline.spec.ts",
    "test:visual:baseline": "node ../scripts/run-cloud-frontend-playwright.js test -c playwright.config.ts tests/e2e/visual-baseline.spec.ts --update-snapshots",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "keywords": [
    "magick-ai",
    "cloud",
    "frontend"
  ],
  "author": "",
  "license": "ISC",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "postcss": ">=8.5.10"
    }
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@swc/helpers": "0.5.15",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "next": "^16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.10",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "vite": "7.3.5",
    "vitest": "^4.1.9"
  }
}
